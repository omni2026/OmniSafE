# OpenAI-compatible API configuration.
# For OpenAI, set OPENAI_API_KEY and leave OPENAI_BASE_URL empty.
# For compatible providers, set OPENAI_BASE_URL or LLM_BASE_URL.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=

# LLM model settings.
LLM_MODEL=gpt-5.5
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=120

# Enable only when your provider supports OpenAI JSON mode.
LLM_JSON_MODE=false
