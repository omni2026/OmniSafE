# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment / secrets
.env
.env.local
.env.*.local

# Editor / IDE
.vscode/
.idea/
*.swp
.DS_Store

# Test / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Module-level generated artifacts
src/*/output/
src/**/output/
test/

# Scene generation: ablation experiments, generated snapshots, output USD files.
# NOTE: the bundled RAG index under src/scene_generation/rag/ IS shipped with
# the repo (it is the USD asset store) and must not be ignored.
src/scene_generation/ablation/
src/scene_generation/**/snapshot_*/
*.usd
*.usda
*.usdc

# src/eval ships its own reviewer-facing assets (eval scenes, Fetch robot
# USDs, the bundled USD server asset package, and the debug scene). Keep them.
!src/eval/data/
!src/eval/data/**
!src/eval/dataset/*.usda
!src/eval/runtime/simulation/Fetch/assets/
!src/eval/runtime/simulation/Fetch/assets/**
