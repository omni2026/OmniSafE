# --- LLM provider keys (fill in the ones you use) ---
ZHIPUAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=

# Optional OpenAI-compatible base URL for the `openai` provider entry in
# configs/default_config.json (e.g. a gateway or a self-hosted endpoint).
OPENAI_BASE_URL=

# Path to the Isaac Sim python executable used to launch the standalone
# simulation subprocess. Set this so sim_manager can spawn Isaac Sim.
#   Windows:  .../isaac-sim/python.bat
#   Linux:    .../isaac-sim/python.sh
ISAACSIM_PYTHON_EXECUTABLE=

# GraspGen ZMQ server (optional). When GRASPGEN_SERVER_ENABLED=false, the
# runtime falls back to a top-down grasp centred on the object's position.
GRASPGEN_SERVER_HOST=
GRASPGEN_SERVER_PORT=5556
GRASPGEN_SERVER_ENABLED=false

# Isaac Sim launch options. These can also be controlled from
# configs/default_config.json -> sim_manager or with `python main.py --headless`.
# Set headless=false or run with `--no-headless` when you need the Isaac Sim UI.
OMNISAFE_ISAAC_HEADLESS=true
OMNISAFE_ISAAC_LIVESTREAM=false
