# Copy this file to .env and fill in real values. Do not commit .env.

# --- LLM provider API keys (at least one is required) ---
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
POE_API_KEY=
ZHIPU_API_KEY=
MINIMAX_API_KEY=

# --- Local paths (referenced by run_config.json via ${VAR} placeholders) ---

# Root of the BEHAVIOR-1K asset dataset on this machine.
# Example: /data/behavior-1k-assets
BEHAVIOR1K_ROOT=

# Root of an installed Isaac Sim build (containing python.bat / python.sh).
# Example: /opt/isaac_sim
ISAAC_SIM_ROOT=

# Python interpreter used to launch the scene-generation driver process.
# Typically the python binary inside your project venv (e.g.
# .venv/Scripts/python.exe on Windows, .venv/bin/python on Linux).
# Leave blank to inherit whatever interpreter is running run_pipeline.py.
PYTHON_EXECUTABLE=

# Default output USD path used when --usd-file is not provided to
# isaac_sim_app.py / isaac_sim_app_graph.py.
# Example: ./output/scene.usda
SCENE_USD_OUTPUT=

# Directory under which timestamped snapshot folders are created by
# record_scene_snapshot. Defaults to ~/scene_snapshots if unset.
SCENE_SNAPSHOT_ROOT=
